{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Diamond Markdown",
  "version": "0.0.1",
  "identifier": "com.primesymbiote.diamondmarkdown",
  "build": {
    "frontendDist": "http://127.0.0.1:3045",
    "devUrl": "http://127.0.0.1:3045",
    "beforeDevCommand": {
      "script": "npm run build",
      "wait": true
    },
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Diamond Markdown",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../build/": "backend/build",
      "../sample-vault/": "sample-vault"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
