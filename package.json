{
	"name": "diamondmd",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"tauri": "tauri",
		"desktop:dev": "tauri dev --no-dev-server-wait",
		"desktop:build": "tauri build",
		"desktop:build:debug": "tauri build --debug --no-bundle",
		"desktop:prepare-node-sidecar": "node scripts/prepare-node-sidecar.mjs",
		"desktop:build:self-contained": "npm run desktop:prepare-node-sidecar && tauri build --config src-tauri/tauri.sidecar.conf.json",
		"desktop:build:self-contained:debug": "npm run desktop:prepare-node-sidecar && tauri build --debug --no-bundle --config src-tauri/tauri.sidecar.conf.json",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui"
	},
	"overrides": {
		"cookie": "0.7.2"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-node": "^5.5.4",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tauri-apps/cli": "^2.11.2",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"vite": "^8.0.7"
	},
	"dependencies": {
		"@codemirror/commands": "^6.10.3",
		"@codemirror/lang-markdown": "^6.5.0",
		"@codemirror/language": "^6.12.3",
		"@codemirror/search": "^6.7.0",
		"@codemirror/state": "^6.6.0",
		"@codemirror/view": "^6.41.1",
		"@lezer/highlight": "^1.2.3",
		"@types/jsdom": "^28.0.1",
		"codemirror": "^6.0.2",
		"dompurify": "^3.4.1",
		"fuse.js": "^7.3.0",
		"highlight.js": "^11.11.1",
		"jsdom": "^29.0.2",
		"katex": "^0.16.45",
		"marked": "^18.0.2",
		"marked-footnote": "^1.4.0",
		"mermaid": "^11.14.0",
		"simple-git": "^3.36.0"
	}
}
